/* app.css - Premium Component Layouts */
body { overflow-x: hidden; overflow-y: auto; background: var(--bg-dark); }

.workspace-layout {
    display: flex;
    height: 100vh;
    width: 100vw;
    position: relative;
    border-bottom: 1px solid rgba(255,255,255,0.1);
}

/* SIDEBAR */
.workspace-sidebar {
    width: 420px;
    background: var(--bg-dark);
    display: flex;
    flex-direction: column;
    z-index: 10;
    border-right: 1px solid var(--border-light);
    box-shadow: 10px 0 30px rgba(0,0,0,0.5);
}

.sidebar-header {
    padding: 30px;
    border-bottom: 1px solid var(--border-light);
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: radial-gradient(circle at left, #121826, transparent);
}
.logo { font-size: 24px; font-weight: 800; font-family: 'Outfit', sans-serif; letter-spacing: -0.5px; }
.user-pill {
    background: rgba(255,255,255,0.05);
    padding: 8px 16px;
    border-radius: 30px;
    font-size: 13px;
    display: flex;
    align-items: center;
    gap: 15px;
    border: 1px solid rgba(255,255,255,0.08);
}
.user-pill button { background: none; border: none; color: #fca5a5; cursor: pointer; display: flex; align-items: center; transition: transform 0.2s; }
.user-pill button:hover { transform: scale(1.1); }

.sidebar-content {
    flex: 1;
    overflow-y: auto;
    padding: 40px 30px;
}
.sidebar-content::-webkit-scrollbar { width: 5px; }
.sidebar-content::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 3px; }

.control-box {
    padding: 30px;
    margin-bottom: 25px;
    background: rgba(255,255,255,0.02);
}

.sidebar-footer {
    padding: 20px 30px;
    border-top: 1px solid var(--border-light);
    text-align: center;
    background: #02040a;
}

/* CUSTOM AUTOCOMPLETE DROPDOWN */
.city-row { display: flex; gap: 10px; align-items: stretch; position: relative; margin-bottom: 10px; }
.autocomplete-wrapper { flex: 1; position: relative; }
.city-input {
    width: 100%;
    padding: 14px 18px;
    background: rgba(0,0,0,0.4);
    border: 1px solid var(--border-light);
    color: #fff;
    border-radius: 12px;
    font-family: inherit;
    font-size: 14px;
    transition: all 0.3s;
}
.city-input:focus {
    outline: none;
    border-color: var(--brand-secondary);
    box-shadow: 0 0 0 3px rgba(255,195,113,0.15);
}
.delete-city {
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
    border: 1px solid rgba(239, 68, 68, 0.2);
    width: 48px;
    border-radius: 12px;
    cursor: pointer;
    transition: background 0.3s, transform 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
}
.delete-city:hover { background: rgba(239, 68, 68, 0.2); transform: scale(1.05); }

.autocomplete-dropdown {
    position: absolute;
    top: calc(100% + 8px);
    left: 0; right: 0;
    background: rgba(14, 18, 28, 0.95);
    backdrop-filter: blur(25px);
    -webkit-backdrop-filter: blur(25px);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.8);
    display: none;
    z-index: 9999;
    max-height: 250px;
    overflow-y: auto;
    overflow-x: hidden;
}
.autocomplete-dropdown::-webkit-scrollbar { width: 5px; }
.autocomplete-dropdown::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.2); border-radius: 2px; }

.autocomplete-item {
    padding: 16px;
    cursor: pointer;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    display: flex;
    align-items: center;
    gap: 12px;
    transition: background 0.2s;
}
.autocomplete-item:last-child { border-bottom: none; }
.autocomplete-item:hover { background: rgba(255,255,255,0.08); }

.ac-icon { font-size: 18px; color: var(--brand-secondary); width: 24px; text-align: center; }
.ac-text { display: flex; flex-direction: column; }
.ac-main { font-size: 14px; color: #fff; font-weight: 600; }
.ac-sub { font-size: 12px; color: #94a3b8; margin-top: 3px; }

/* MAP */
.workspace-map {
    flex: 1;
    position: relative;
    background: #02040a;
}
#map { width: 100%; height: 100%; z-index: 1; }
.leaflet-container { background: #070a13; font-family: 'Inter', sans-serif;}

/* SECTIONS & GRID CARDS */
.analytics-card {
    background: rgba(20, 24, 36, 0.4);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 24px;
    padding: 40px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
}
.route-card {
    background: rgba(20, 24, 36, 0.4);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 20px;
    padding: 30px;
}
.route-leg {
    display: flex;
    align-items: center;
    padding: 16px 0;
    border-bottom: 1px dashed rgba(255,255,255,0.05);
}
.route-leg:last-child { border-bottom: none; padding-bottom: 0; }

.svg-block {
    background: rgba(0,0,0,0.4);
    padding: 24px;
    border-radius: 20px;
    border: 1px solid rgba(255,255,255,0.05);
    box-shadow: 0 10px 30px -10px rgba(0,0,0,0.5);
    display: flex;
    flex-direction: column;
}
.block-optimal { background: rgba(255,195,113,0.05); border: 1px solid rgba(251,146,60,0.3); }

/* ANALYSIS SPLIT LAYOUT (2 COLUMNS) */
.analysis-split-layout {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 80px;
    align-items: start;
}

/* BADGES */
.badge {
    padding: 4px 12px;
    border-radius: 8px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}
.badge-normal { background: rgba(148,163,184,0.1); color: #94a3b8; border: 1px solid rgba(148,163,184,0.2); }
.badge-fast { background: rgba(16,185,129,0.1); color: #10b981; border: 1px solid rgba(16,185,129,0.2); }
.badge-optimal { background: rgba(251,146,60,0.15); color: #fb923c; border: 1px solid rgba(251,146,60,0.3); }

/* MATRIX TABLE */
#matrix table { width: 100%; border-collapse: collapse; margin-top: 20px; }
#matrix th, #matrix td { border: 1px dashed rgba(255,255,255,0.1); padding: 16px; text-align: center; color:#e2e8f0; }
#matrix th { background: rgba(255,255,255,0.02); color: var(--brand-secondary); font-weight:700; text-transform:uppercase; letter-spacing:1px; font-size:12px;}

/* MAP LABEL OVERLAYS */
.distance-tooltip {
    background: rgba(10,13,20, 0.98) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    box-shadow: 0 20px 50px rgba(0,0,0,1) !important;
    border-radius: 16px !important;
    font-size: 14px !important;
    font-family: 'Outfit', sans-serif !important;
    padding: 0px !important;
}
.distance-tooltip::before { display: none !important; }

/* Fixed Map City Labels */
.city-label-map {
    background: transparent !important;
    border: none !important;
    box-shadow: none !important;
    color: #fff !important;
    font-size: 13px !important;
    font-weight: 700 !important;
    font-family: 'Outfit', sans-serif !important;
    text-shadow: 0px 2px 4px #000, 0px 0px 10px #000, 0px 0px 15px #000 !important;
}
.city-label-map::before { display: none !important; }

/* Custom Leaflet Controls */
.leaflet-control-zoom { border: none !important; box-shadow: 0 10px 40px rgba(0,0,0,0.8) !important; margin-right: 24px !important; margin-top: 24px !important; }
.leaflet-control-zoom a { background: var(--bg-card) !important; color: #fff !important; border-color: var(--border-light) !important; backdrop-filter: blur(10px); width:36px !important; height:36px !important; line-height:36px !important; font-size: 18px !important; transition:0.3s;}
.leaflet-control-zoom a:hover { background: rgba(255,255,255,0.15) !important; color:#fff !important; }

@media (max-width: 1000px) {
    .workspace-layout { flex-direction: column; height: auto; }
    .workspace-sidebar { width: 100%; height: auto; border-right: none; border-bottom: 1px solid var(--border-light); }
    .workspace-map { height: 60vh; width: 100%; }
    .analysis-split-layout { grid-template-columns: 1fr; }
    .structure-side #svgContainer { padding-right: 0; }
}
