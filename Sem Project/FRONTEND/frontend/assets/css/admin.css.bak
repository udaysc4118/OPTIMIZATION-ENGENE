/* admin.css */

.command-center {
    display: flex;
    height: 100vh;
    background: #02040a;
}

.cc-sidebar {
    width: 280px;
    background: #060913;
    border-right: 1px solid var(--border-light);
    display: flex;
    flex-direction: column;
    padding: 30px 20px;
}

.cc-sidebar .logo { font-size: 22px; margin-bottom: 50px; padding-left: 10px; }

.cc-menu { list-style: none; flex: 1; margin: 0; padding: 0; }
.cc-menu li {
    padding: 14px 20px;
    margin-bottom: 8px;
    border-radius: 12px;
    color: var(--text-muted);
    font-weight: 500;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 12px;
    transition: all 0.3s var(--ease-out);
}
.cc-menu li i { font-size: 20px; }
.cc-menu li:hover { background: rgba(255,255,255,0.05); color: #fff; }
.cc-menu li.active { background: var(--brand-secondary); color: #000; font-weight: 700; box-shadow: 0 4px 15px rgba(255,195,113,0.3); }

.logout-btn {
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
    border: 1px solid rgba(239, 68, 68, 0.2);
    padding: 14px;
    border-radius: 12px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    font-family: 'Inter', sans-serif;
}
.logout-btn:hover { background: #ef4444; color: #fff; box-shadow: 0 4px 15px rgba(239,68,68,0.4); }

.cc-main {
    flex: 1;
    padding: 40px;
    overflow-y: auto;
}

.cc-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 40px;
}
.cc-header h1 { font-size: 36px; }
.cc-header p { color: var(--text-muted); font-size: 16px; margin-top:5px; }

.user-stats {
    padding: 20px 30px;
    display: inline-block;
    border-radius: 16px;
    background: rgba(20,24,36,0.3);
}

.stat-group { display: flex; align-items: center; gap: 15px; }
.stat-icon { font-size: 32px; color: var(--brand-secondary); }
.stat-group div { display: flex; flex-direction: column; }
.val { font-size: 28px; font-weight: 800; font-family: 'Outfit'; line-height: 1; }
.lbl { font-size: 12px; color: var(--text-muted); text-transform: uppercase; font-weight: 600; letter-spacing: 0.5px; margin-top:4px;}

/* Table Styles */
.table-container {
    padding: 25px;
    background: rgba(20,24,36,0.4);
    box-shadow: 0 20px 40px rgba(0,0,0,0.5);
    border-radius: 20px;
}

.toolbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; }
.toolbar h2 { font-size: 22px; }

.cc-table { width: 100%; border-collapse: separate; border-spacing: 0 8px; }
.cc-table th {
    text-align: left;
    padding: 10px 20px;
    color: var(--text-muted);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
}

.cc-table td {
    padding: 18px 20px;
    background: rgba(0,0,0,0.4);
    font-size: 14px;
    font-weight: 500;
    color: #e2e8f0;
    transition: background 0.3s;
}
.cc-table tr:hover td { background: rgba(255, 195, 113, 0.05); }

.cc-table td:first-child { border-top-left-radius: 12px; border-bottom-left-radius: 12px; font-family: monospace; color: var(--text-muted); font-size:13px; }
.cc-table td:last-child { border-top-right-radius: 12px; border-bottom-right-radius: 12px; }

.uuid { background: rgba(255,255,255,0.05); padding: 4px 8px; border-radius: 6px; }

/* Action Buttons */
.action-btn {
    background: transparent;
    border: none;
    color: var(--text-muted);
    font-size: 18px;
    cursor: pointer;
    padding: 8px;
    border-radius: 8px;
    transition: all 0.2s;
    margin-left: 5px;
}
.btn-edit:hover { background: rgba(59, 130, 246, 0.2); color: #60a5fa; }
.btn-del:hover { background: rgba(239, 68, 68, 0.2); color: #f87171; }

/* Modal */
.modal-overlay {
    position: fixed; inset: 0; background: rgba(0,0,0,0.8);
    display: flex; justify-content: center; align-items: center; z-index: 9999;
    backdrop-filter: blur(10px);
    animation: fadeIn 0.3s var(--ease-out);
}

@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

.modal-box {
    width: 100%; max-width: 450px; padding: 40px; background: rgba(14,17,26,0.95);
    border: 1px solid rgba(255,195,113,0.3); border-radius: 24px;
    box-shadow: 0 40px 80px rgba(0,0,0,0.9);
    animation: modalPop 0.4s var(--ease-out);
}

@keyframes modalPop { 
    from { opacity: 0; transform: scale(0.95) translateY(20px); } 
    to { opacity: 1; transform: scale(1) translateY(0); } 
}

.modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
.modal-header h2 { font-size: 24px; }
.close-btn { background: none; border: none; color: var(--text-muted); font-size: 24px; cursor: pointer; transition: color 0.2s; }
.close-btn:hover { color: #ef4444; }
